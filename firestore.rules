// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields:
//   - uid: string (required)
//   - displayName: string (required)
//   - photoURL: string (optional)
//   - email: string (required)
//   - age: number (optional)
//   - gender: string (optional)
//   - city: string (optional)
//   - isVerified: boolean (optional)
//
// Collection: trips
// Fields:
//   - ownerUid: string (required)
//   - ownerName: string (required)
//   - destination: string (required)
//   - travelDate: string (required)
//   - lookingFor: string (required)
//   - description: string (optional)
//   - createdAt: timestamp (required)
//
// Collection: requests
// Fields:
//   - tripId: string (required)
//   - tripOwnerUid: string (required)
//   - requesterUid: string (required)
//   - requesterName: string (required)
//   - requesterPhone: string (required) - Shared with owner
//   - ownerPhone: string (optional) - Shared with requester after accept
//   - status: string (pending, accepted, rejected)
//   - createdAt: timestamp (required)
//
// Collection: teams
// Fields:
//   - tripId: string (required)
//   - members: list of strings (uids)
//   - createdAt: timestamp (required)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "saketkulthe29939@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Only owner can read their own profile (PII protection)
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid &&
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
    }

    function isValidUser(data) {
      return hasRequiredFields(data, ['uid', 'displayName', 'email']) &&
             data.uid is string && data.displayName is string &&
             data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() < 20)) &&
             (!('role' in data) || data.role in ['user', 'admin']) &&
             (!('trustScore' in data) || (data.trustScore is number && data.trustScore >= 0 && data.trustScore <= 100)) &&
             (!('verificationLevel' in data) || data.verificationLevel in ['Highly Trusted', 'Verified Traveler', 'Partially Verified', 'Unverified']);
    }

    match /trips/{tripId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid && isValidTrip(request.resource.data);
      allow update: if isAuthenticated() && resource.data.ownerUid == request.auth.uid && isValidTrip(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
    }

    function isValidTrip(data) {
      return hasRequiredFields(data, ['ownerUid', 'destination', 'travelDate', 'lookingFor', 'createdAt']) &&
             data.ownerUid == request.auth.uid &&
             data.destination is string && data.destination.size() > 0 && data.destination.size() < 100 &&
             data.lookingFor in ['Solo', 'Group', 'Male', 'Female', 'Anyone'];
    }

    match /requests/{requestId} {
      // Both requester and owner can read the request
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.requesterUid || 
        request.auth.uid == resource.data.tripOwnerUid ||
        get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.ownerUid == request.auth.uid
      );
      
      // Only requester can create a pending request
      allow create: if isAuthenticated() && 
                    request.resource.data.requesterUid == request.auth.uid && 
                    request.resource.data.status == 'pending' &&
                    isValidRequest(request.resource.data);
      
      // Owner can accept/reject, Requester can cancel
      allow update: if isAuthenticated() && (
        ((request.auth.uid == resource.data.tripOwnerUid || get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.ownerUid == request.auth.uid) && 
         request.resource.data.status in ['accepted', 'rejected'] && isValidRequestUpdate(request.resource.data)) ||
        (request.auth.uid == resource.data.requesterUid && request.resource.data.status == 'cancelled')
      );
    }

    function isValidRequest(data) {
      return hasRequiredFields(data, ['tripId', 'tripOwnerUid', 'requesterUid', 'requesterName', 'requesterPhone', 'status', 'createdAt']) &&
             data.requesterPhone is string && data.requesterPhone.size() >= 10 && data.requesterPhone.size() <= 15;
    }

    function isValidRequestUpdate(data) {
      // If accepting, owner must provide their phone number
      return (data.status == 'accepted' ? hasRequiredFields(data, ['ownerPhone']) && data.ownerPhone is string : true);
    }

    match /teams/{teamId} {
      // Allow reading if user is a member or the trip owner
      allow read: if isAuthenticated() && (
        (resource != null && request.auth.uid in resource.data.members) || 
        get(/databases/$(database)/documents/trips/$(teamId)).data.ownerUid == request.auth.uid
      );
      
      // Allow creation if the creator is the trip owner
      allow create: if isAuthenticated() && 
                    get(/databases/$(database)/documents/trips/$(teamId)).data.ownerUid == request.auth.uid &&
                    request.resource.data.ownerUid == request.auth.uid &&
                    hasRequiredFields(request.resource.data, ['tripId', 'members', 'createdAt']);
      
      // Allow updating if the user is a member or the trip owner
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.members ||
        get(/databases/$(database)/documents/trips/$(teamId)).data.ownerUid == request.auth.uid
      );
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && 
                  request.auth.uid in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.members;
      
      allow create: if isAuthenticated() && 
                    request.resource.data.senderUid == request.auth.uid &&
                    request.auth.uid in get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.members &&
                    isValidMessage(request.resource.data);
    }

    function isValidMessage(data) {
      return hasRequiredFields(data, ['teamId', 'senderUid', 'senderName', 'text', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
